@model Gumani_Moila_EAPD7111w_POE.Models.Client

@{
    ViewData["Title"] = "Create";
}

<div class="w-full flex justify-start mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span>Back</span>
    </a>
</div>

        <form asp-action="Create" class="w-full max-w-2xl mx-auto">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-center"></div>
    <p class="text-lg text-center font-medium mb-6">Create new client</p>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
            <div>
            <label asp-for="ClientName" class="text-sm font-sm"></label>
            <input asp-for="ClientName" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
                <span asp-validation-for="ClientName" class="text-red-600"></span>
            </div>
            <div >
            <label asp-for="ContactDetails" class="text-sm font-sm"></label>
            <input asp-for="ContactDetails" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
                <span asp-validation-for="ContactDetails" class="text-red-600"></span>
            </div>
            <div >
            <label asp-for="ClientRegion" class="text-sm font-sm"></label>
            <input asp-for="ClientRegion" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
                <span asp-validation-for="ClientRegion" class="text-red-600"></span>
            </div>
            </div>
    <div class="flex justify-center mt-6">
        <input type="submit" value="Create" class="w-full px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all" />
    </div>
        </form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
