@model IEnumerable<Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest>

@{
    ViewData["Title"] = "Index";
}

<div class="w-full flex justify-between items-center mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span class="text-sm">Back</span>
    </a>
    <a asp-action="Create" class="bg-blue-600 text-sm py-2 px-3 rounded text-white">Add service request</a>
</div>

<div class="flex flex-wrap gap-3 p-12 justify-center items-center">
@foreach (var item in Model) {
        <div class="max-w-sm w-full shadow-sm rounded py-2 px-2">
            <div class="flex justify-between items-center flex-row w-full">
                <p class="text-sm font-medium">     @item.Cost.ToString("C", new System.Globalization.CultureInfo("en-ZA"))</p>
                @* // status badge *@
                <span class="text-xs font-medium px-2 py-1 rounded-full @(item.Status == Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest.ServiceRequestStatus.completed
                          ? "bg-green-100 text-green-800" 
                                                                      : item.Status == Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest.ServiceRequestStatus.pending ? "bg-blue-100 text-blue-800" : item.Status == Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest.ServiceRequestStatus.inProgress
                              ? "bg-yellow-100 text-yellow-800" 
                              : "bg-red-100 text-red-800")">
                    @Html.DisplayFor(modelItem => item.Status)
                </span>
                </div>
            <p class="text-xs font-medium capitalize">Contract id: @Html.DisplayFor(modelItem => item.ContractId)</p>
            @* <p class="text-xs font-medium class=" text-xs font-medium capitalize"">@Html.DisplayFor(modelItem => item.Contract.Client.ClientName)</p> *@
               <p class="text-sm font-medium">@Html.DisplayFor(modelItem => item.Description)</p>

            <div class="flex justify-between items-center flex-row">
                <a asp-action="Edit" class="text-blue-600 text-sm" asp-route-id="@item.Id"><i class="fa-regular fa-pen-to-square"></i></a>
                <a asp-action="Delete" class="text-red-600 text-sm" asp-route-id="@item.Id"><i class="fa-regular fa-trash-can"></i></a>
            </div>

           </div>
}
  </div>
