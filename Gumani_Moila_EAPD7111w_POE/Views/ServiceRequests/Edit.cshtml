@model Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest

@{
    ViewData["Title"] = "Edit";
}


<div class="w-full flex justify-start mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span class="text-sm">Back</span>
    </a>
</div>
<form asp-action="Edit" class="w-full max-w-2xl mx-auto">
    @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-center"></div>
            <input type="hidden" asp-for="Id" />
    <p class="text-lg text-center font-medium mb-6">Edit Service Request</p>
    @* // Responsive grid: 2 columns on medium+, 1 column on small  *@
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
            <label asp-for="Cost" class="text-sm font-sm"></label>
            <input asp-for="Cost" id="CostInput"
                   class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="Cost" class="text-red-600"></span>

          @*   // Display converted Rand amount  *@
            <p id="RandDisplay" class="text-green-700 mt-2 font-medium"></p>
        </div>
        <div>
            <label asp-for="Status" class="text-sm font-sm"></label>
            <select asp-for="Status" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100" asp-items="@Html.GetEnumSelectList<Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest.ServiceRequestStatus>()"></select>
            <span asp-validation-for="Status" class="text-red-600"></span>
        </div>
        
            <div >
                <label asp-for="ContractId" class="control-label"></label>
            <select asp-for="ContractId" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100" asp-items="ViewBag.ContractId"></select>
                <span asp-validation-for="ContractId" class="text-red-600"></span>
            </div>
        <div>
            <label asp-for="Type" class="text-sm font-sm"></label>

            <select asp-for="Type"
                    class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100"
                    asp-items="@Html.GetEnumSelectList<Gumani_Moila_EAPD7111w_POE.Models.ServiceRequest.RequestType>()">
            </select>

            <span asp-validation-for="Type" class="text-red-600"></span>
        </div>
        <div>
            <label asp-for="Description" class="text-sm font-sm"></label>
            <input asp-for="Description" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="Description" class="text-red-600"></span>
        </div>
        </div>
    <div class="flex justify-center mt-6">
        <input type="submit" value="Save" class="w-full px-6 py-2 bg-black text-white rounded-lg hover:bg-blue-700 transition-all" />
    </div>
        </form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const costInput = document.getElementById("CostInput");
            const randDisplay = document.getElementById("RandDisplay");

            costInput.addEventListener("input", async function () {
                const value = parseFloat(costInput.value);
                if (!isNaN(value)) {
                    try {
                        // Call your backend API
                        const response = await fetch(`/ServiceRequests/GetConvertedCurrency?amount=${value}`);
                        if (!response.ok) throw new Error("API error");

                        const data = await response.json();
                        randDisplay.textContent = `≈ R ${data.convertedAmount.toFixed(2)}`;
                    } catch (err) {
                        randDisplay.textContent = "Conversion failed";
                        console.error(err);
                    }
                } else {
                    randDisplay.textContent = "";
                }
            });
        });
    </script>
}
}
