@model IEnumerable<Gumani_Moila_EAPD7111w_POE.Models.Contract>

@{
    ViewData["Title"] = "Index";
}

<div class="w-full flex justify-between items-center mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span class="text-sm">Back</span>
    </a>
    <a asp-action="Create" class="bg-blue-600 text-sm py-2 px-3 rounded text-white">Add contract</a>
</div>

@* // search contract by date range and status *@
<form asp-action="Index" method="get" class="max-w-md flex flex-col gap-3 items-center justify-center mx-auto">
    <div class="max-w-md flex flex-row gap-5 items-center justify-center">
        <div>
            <label for="fromDate" class="block text-sm font-medium text-gray-700">From Date</label>
            <input type="date" id="fromDate" name="fromDate"
                   value="@ViewData["FromDate"]"
                   class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all">
        </div>
        <div>
            <label for="toDate" class="block text-sm font-medium text-gray-700">To Date</label>
            <input type="date" id="toDate" name="toDate"
                   value="@ViewData["ToDate"]"
                   class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all">
        </div>
    </div>

    <!-- Status filter -->
    <div class="max-w-md flex flex-row gap-3 items-center justify-center mt-4">
        <input type="hidden" id="statusInput" name="status"  value="@ViewData["Status"]" />

        <div class="px-3 py-1 rounded-full bg-black cursor-pointer status-menu" data-value="All">
            <p class="text-xs text-white font-normal">All</p>
        </div>

        @foreach (var status in Enum.GetValues(typeof(Gumani_Moila_EAPD7111w_POE.Models.Contract.ContractStatus)))
        {
            <div class="px-3 py-1 rounded-full bg-gray-200 cursor-pointer status-menu" data-value="@status">
                <p class="text-xs text-black font-normal">@status</p>
            </div>
        }
    </div>

    <div class="flex justify-center mt-6">
        <button type="submit"
                class="px-6 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-all">
            Search
        </button>
    </div>
</form>







<div class="flex flex-wrap gap-3 p-12 justify-center items-center">

@foreach (var item in Model) {
    <div class="max-w-sm w-full shadow-sm rounded py-2 px-2">

    <div class="flex justify-between items-center flex-row w-full">
        <p class="text-xs font-medium capitalize">@Html.DisplayFor(modelItem => item.Client.ClientName)</p>
        @* // status badge  *@
                <span class="text-sm font-medium px-2 py-1 rounded-full @(item.Status == Gumani_Moila_EAPD7111w_POE.Models.Contract.ContractStatus.active
                          ? "bg-green-100 text-green-800" 
                          : item.Status == Gumani_Moila_EAPD7111w_POE.Models.Contract.ContractStatus.draft
                              ? "bg-yellow-100 text-yellow-800" 
                              : "bg-red-100 text-red-800")">
                    @Html.DisplayFor(modelItem => item.Status)
                </span>

    </div>
    <p class="text-sm text-gray-700 font-normal">Start Date: @Html.DisplayFor(modelItem => item.StartDate)</p>
    <p class="text-sm text-gray-700 font-normal">End Date: @Html.DisplayFor(modelItem => item.EndDate)</p>
            <div class="flex justify-between items-center flex-row">
                <a class="text-xs text-blue-600" asp-action="DownloadAgreement"
                   asp-route-id="@item.ContractId"><i class="fa-solid fa-file-arrow-down"></i> Agreement</a>
                <div class="flex flex-row gap-4">

                    <a asp-action="Edit" class="text-blue-600 text-sm" asp-route-id="@item.ContractId"><i class="fa-regular fa-pen-to-square"></i></a>
                    <a asp-action="Delete" class="text-red-600 text-sm" asp-route-id="@item.ContractId"><i class="fa-regular fa-trash-can"></i></a>
                </div>
            </div>

</div>
}
    </div>

<script>
    document.addEventListener("DOMContentLoaded", function () {
        const statusInput = document.getElementById("statusInput");
        const statusMenus = document.querySelectorAll(".status-menu");

        // Highlight the pill that matches the current status
        statusMenus.forEach(m => {
            const text = m.querySelector("p");
            if (m.dataset.value === statusInput.value) {
                m.classList.remove("bg-gray-200");
                m.classList.add("bg-black");
                text.classList.remove("text-black");
                text.classList.add("text-white");
            } else {
                m.classList.remove("bg-black");
                m.classList.add("bg-gray-200");
                text.classList.remove("text-white");
                text.classList.add("text-black");
            }
        });

        // Handle clicks
        statusMenus.forEach(menu => {
            menu.addEventListener("click", function () {
                statusMenus.forEach(m => {
                    m.classList.remove("bg-black");
                    m.classList.add("bg-gray-200");
                    const text = m.querySelector("p");
                    text.classList.remove("text-white");
                    text.classList.add("text-black");
                });

                this.classList.remove("bg-gray-200");
                this.classList.add("bg-black");
                const selectedText = this.querySelector("p");
                selectedText.classList.remove("text-black");
                selectedText.classList.add("text-white");

                statusInput.value = this.dataset.value;
            });
        });
    });
</script>

