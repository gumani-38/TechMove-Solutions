@model Gumani_Moila_EAPD7111w_POE.Models.Contract

@{
    ViewData["Title"] = "Edit";
}

<div class="w-full flex justify-start mb-20 px-4">
    <a href="javascript:history.back()"
       class="inline-flex items-center px-3 py-2 rounded-lg bg-gray-200 text-gray-700 hover:bg-gray-300 transition-all shadow-sm">
        <i class="fa-solid fa-arrow-left mr-2"></i>
        <span class="text-sm">Back</span>
    </a>
</div>
<form asp-action="Edit" class="w-full max-w-2xl mx-auto">
            <div asp-validation-summary="ModelOnly" class="text-red-600 text-center"></div>
            <input type="hidden" asp-for="ContractId" />
    <p class="text-lg text-center font-medium mb-6">Edit  contract</p>

    <!-- Responsive grid: 2 columns on medium+, 1 column on small -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        <div>
            <label asp-for="StartDate" class="text-sm font-sm"></label>
            <input asp-for="StartDate" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
            <span asp-validation-for="StartDate" class="text-red-600"></span>
        </div>
            <div>
                <label asp-for="EndDate" class="text-sm font-sm"></label>
                <input asp-for="EndDate" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100 focus:ring-2 focus:ring-blue-600 focus:border-transparent outline-none transition-all" />
                <span asp-validation-for="EndDate" class="text-red-600"></span>
            </div>
            <div >
            <label asp-for="Status" class="text-sm font-sm"></label>
            <select asp-for="Status" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100" asp-items="@Html.GetEnumSelectList<Gumani_Moila_EAPD7111w_POE.Models.Contract.ContractStatus>()"></select>
                <span asp-validation-for="Status" class="text-red-600"></span>
            </div>
            <div >
            <label asp-for="ClientId" class="text-sm font-sm"></label>
            <select asp-for="ClientId" class="w-full px-3 py-2 rounded-lg border border-gray-300 bg-gray-100" asp-items="ViewBag.ClientId"></select>
                <span asp-validation-for="ClientId" class="text-red-600"></span>
            </div>
    </div>
    <div class="flex justify-center mt-6">
        <input type="submit" value="Save" class="w-full px-6 py-2 bg-black text-white rounded-lg hover:bg-blue-700 transition-all" />
    </div>
        </form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
